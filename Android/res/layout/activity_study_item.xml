<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/ll_share_item"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    android:background="@color/main_item_back"
    android:orientation="vertical" >

    <LinearLayout
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/common_fitheight_10px"
        android:orientation="vertical" >

    </LinearLayout>

    <LinearLayout
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal" >

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="fill_parent"
            android:layout_weight="3" >

        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="fill_parent"
            android:layout_weight="200"
            android:orientation="vertical" >

            <LinearLayout
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/share_itemback_top"
                android:orientation="vertical" >

            </LinearLayout>

            <LinearLayout
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/share_itemback_middle"
                android:orientation="vertical" >

                <LinearLayout
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/common_fitheight_5px"
                    android:orientation="vertical" >
                </LinearLayout>

                <LinearLayout
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" >

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="fill_parent"
                        android:layout_weight="10" >
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="fill_parent"
                        android:layout_weight="300" >

                        <com.damy.Utils.AutoSizeTextView
                            android:id="@+id/lab_studyitem_title"
                            android:layout_width="fill_parent"
                            android:layout_height="fill_parent"
                            android:gravity="left|center_vertical"
                            android:textColor="@color/color_black"
                            android:textSize="@dimen/faq_item_title_fontsize" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="fill_parent"
                        android:layout_weight="10" >
                    </LinearLayout>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/common_fitheight_15px"
                    android:orientation="vertical" >
                </LinearLayout>

                <LinearLayout
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" >

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="fill_parent"
                        android:layout_weight="10" >
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="fill_parent"
                        android:layout_weight="300" >

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="fill_parent"
                            android:layout_weight="50" >

                            <com.damy.Utils.AutoSizeTextView
                                android:id="@+id/AutoSizeTextView01"
                                android:layout_width="wrap_content"
                                android:layout_height="fill_parent"
                                android:gravity="left|center_vertical"
                                android:text="@string/study_item_updatedate"
                                android:textColor="@color/faq_item_body"
                                android:textSize="@dimen/faq_item_body_fontsize" />

                            <com.damy.Utils.AutoSizeTextView
                                android:id="@+id/lab_studyitem_updatedate"
                                android:layout_width="wrap_content"
                                android:layout_height="fill_parent"
                                android:gravity="left|center_vertical"
                                android:textColor="@color/faq_item_body"
                                android:textSize="@dimen/faq_item_body_fontsize" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="fill_parent"
                            android:layout_weight="30" >

                            <com.damy.Utils.AutoSizeTextView
                                android:id="@+id/AutoSizeTextView05"
                                android:layout_width="wrap_content"
                                android:layout_height="fill_parent"
                                android:gravity="left|center_vertical"
                                android:text="@string/study_item_readcount"
                                android:textColor="@color/faq_item_body"
                                android:textSize="@dimen/faq_item_body_fontsize" />

                            <com.damy.Utils.AutoSizeTextView
                                android:id="@+id/lab_studyitem_readcount"
                                android:layout_width="wrap_content"
                                android:layout_height="fill_parent"
                                android:gravity="left|center_vertical"
                                android:textColor="@color/faq_item_body"
                                android:textSize="@dimen/faq_item_body_fontsize" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="fill_parent"
                            android:layout_weight="20"
                            android:gravity="right" >

                            <com.damy.Utils.AutoSizeTextView
                                android:id="@+id/AutoSizeTextView07"
                                android:layout_width="wrap_content"
                                android:layout_height="fill_parent"
                                android:gravity="left|center_vertical"
                                android:text="@string/study_item_answer"
                                android:textColor="@color/faq_item_body"
                                android:textSize="@dimen/faq_item_body_fontsize" />

                            <com.damy.Utils.AutoSizeTextView
                                android:id="@+id/lab_studyitem_answer"
                                android:layout_width="wrap_content"
                                android:layout_height="fill_parent"
                                android:gravity="left|center_vertical"
                                android:textColor="@color/faq_item_body"
                                android:textSize="@dimen/faq_item_body_fontsize" />
                        </LinearLayout>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="fill_parent"
                        android:layout_weight="10" >
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/common_fitheight_15px"
                    android:orientation="vertical" >
                </LinearLayout>

                <LinearLayout
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" >

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="fill_parent"
                        android:layout_weight="10" >
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="fill_parent"
                        android:layout_weight="300"
                        android:orientation="horizontal" >

                        <com.damy.Utils.AutoSizeTextView
                            android:id="@+id/lab_studyitem_body"
                            android:layout_width="fill_parent"
                            android:layout_height="fill_parent"
                            android:layout_weight="70"
                            android:gravity="left|center_vertical"
                            android:textColor="@color/share_item_body"
                            android:textSize="@dimen/faq_item_body_fontsize" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="fill_parent"
                        android:layout_weight="10" >
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/common_fitheight_20px"
                    android:orientation="vertical" >
                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/share_itemback_bottom"
                android:orientation="vertical" >

            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="fill_parent"
            android:layout_weight="3" >
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
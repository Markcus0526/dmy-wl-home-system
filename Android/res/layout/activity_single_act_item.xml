<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/qa_scroll_item"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    android:background="@color/main_item_back"
    android:orientation="vertical" >

    <LinearLayout
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/common_fitheight_15px"
        android:orientation="vertical" >
    </LinearLayout>

    <LinearLayout
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal" >

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="fill_parent"
            android:layout_weight="3" >

        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="fill_parent"
            android:layout_weight="200"
            android:orientation="horizontal" >

            <LinearLayout
                android:layout_width="1px"
                android:layout_height="fill_parent"
                android:background="@color/activity_item_line_color" >
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="96"
                android:orientation="vertical" >

                <LinearLayout
                    android:layout_width="fill_parent"
                    android:layout_height="1px"
                    android:background="@color/activity_item_line_color"
                    android:orientation="vertical" >
                </LinearLayout>

                <LinearLayout
                    android:layout_width="fill_parent"
                    android:layout_height="fill_parent" >

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="fill_parent"
                        android:layout_weight="2" >
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="fill_parent"
                        android:layout_weight="96"
                        android:orientation="vertical" >

                        <LinearLayout
                            android:layout_width="fill_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/common_fitheight_5px"
                            android:orientation="vertical" >
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="fill_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical" >

                            <com.damy.Utils.AutoSizeTextView
                                android:id="@+id/single_act_item_title"
                                android:layout_width="wrap_content"
                                android:layout_height="fill_parent"
                                android:gravity="left|center_vertical"
                                android:textColor="@color/color_black"
                                android:textSize="@dimen/activity_item_title_fontsize" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="fill_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/common_fitheight_10px"
                            android:orientation="vertical" >
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="fill_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal" >

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="fill_parent"
                                android:layout_weight="70" >

                                <com.damy.Utils.AutoSizeTextView
                                    android:id="@+id/single_act_item_date"
                                    android:layout_width="wrap_content"
                                    android:layout_height="fill_parent"
                                    android:gravity="left|center_vertical"
                                    android:textColor="@color/activity_item_body"
                                    android:textSize="@dimen/date_fontsize" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="fill_parent"
                                android:layout_weight="30" >

                                <com.damy.Utils.AutoSizeTextView
                                    android:id="@+id/autoSizeTextView1"
                                    android:layout_width="wrap_content"
                                    android:layout_height="fill_parent"
                                    android:gravity="left|center_vertical"
                                    android:text="@string/eval_comma"
                                    android:textColor="@color/activity_item_body"
                                    android:textSize="@dimen/activity_item_body_fontsize" />

                                <com.damy.Utils.AutoSizeTextView
                                    android:id="@+id/single_act_item_evalcnt"
                                    android:layout_width="wrap_content"
                                    android:layout_height="fill_parent"
                                    android:gravity="left|center_vertical"
                                    android:textColor="@color/activity_item_body"
                                    android:textSize="@dimen/date_fontsize" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="fill_parent"
                                android:layout_weight="30" >

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="fill_parent"
                                    android:layout_weight="10"
                                    android:gravity="right|center_vertical" >

                                    <ImageView
                                        android:id="@+id/imageView1"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:src="@drawable/main_smileface" />

                                    <com.damy.Utils.AutoSizeTextView
                                        android:id="@+id/autoSizeTextView2"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text=" " />

                                    <com.damy.Utils.AutoSizeTextView
                                        android:id="@+id/single_act_item_readcnt"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:gravity="center_vertical|center_horizontal"
                                        android:textColor="@color/activity_item_body"
                                        android:textSize="@dimen/activity_item_body_fontsize" />
                                </LinearLayout>
                            </LinearLayout>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="fill_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/common_fitheight_15px"
                            android:orientation="vertical" >
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/ll_single_image"
                            android:layout_width="fill_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal" >

                            <LinearLayout
                                android:id="@+id/ll_single_act_item_imagelayer1"
                                android:layout_width="0dp"
                                android:layout_height="fill_parent"
                                android:layout_weight="30" >

                                <ImageView
                                    android:id="@+id/single_act_item_image1"
                                    android:layout_width="fill_parent"
                                    android:layout_height="fill_parent"
                                    android:adjustViewBounds="true"
                                    android:scaleType="fitCenter" />

                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="fill_parent"
                                android:layout_weight="10" >
                            </LinearLayout>

                            <LinearLayout
                                android:id="@+id/ll_single_act_item_imagelayer2"
                                android:layout_width="0dp"
                                android:layout_height="fill_parent"
                                android:layout_weight="30" >

                                <ImageView
                                    android:id="@+id/single_act_item_image2"
                                    android:layout_width="fill_parent"
                                    android:layout_height="fill_parent"
                                    android:adjustViewBounds="true"
                                    android:scaleType="fitCenter" />

                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="fill_parent"
                                android:layout_weight="10" >
                            </LinearLayout>

                            <LinearLayout
                                android:id="@+id/ll_single_act_item_imagelayer3"
                                android:layout_width="0dp"
                                android:layout_height="fill_parent"
                                android:layout_weight="30" >

                                <ImageView
                                    android:id="@+id/single_act_item_image3"
                                    android:layout_width="fill_parent"
                                    android:layout_height="fill_parent"
                                    android:adjustViewBounds="true"
                                    android:scaleType="fitCenter" />

                            </LinearLayout>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="fill_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/common_fitheight_15px"
                            android:orientation="vertical" >
                        </LinearLayout>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="fill_parent"
                        android:layout_weight="2" >
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="fill_parent"
                    android:layout_height="1px"
                    android:background="@color/activity_item_line_color"
                    android:orientation="vertical" >
                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:layout_width="1px"
                android:layout_height="fill_parent"
                android:background="@color/activity_item_line_color" >
            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="fill_parent"
            android:layout_weight="3" >
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
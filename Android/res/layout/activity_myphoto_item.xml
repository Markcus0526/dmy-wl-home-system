<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/ll_myphoto_item"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    android:background="@color/main_item_back"
    android:orientation="vertical" >

    <LinearLayout
        android:layout_width="fill_parent"
        android:layout_height="0dp"
        android:layout_weight="100"
        android:orientation="horizontal" >

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="fill_parent"
            android:layout_weight="5" >

        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="fill_parent"
            android:layout_weight="100"
            android:orientation="vertical" >

            <LinearLayout
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/common_fitheight_15px"
                android:orientation="vertical" >

            </LinearLayout>

            <LinearLayout
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal" >

                <LinearLayout
                    android:id="@+id/ll_myphoto_item_imagelayer1"
                    android:layout_width="0dp"
                    android:layout_height="fill_parent"
                    android:layout_weight="50" >

                    <ImageView
                        android:id="@+id/img_myphoto_item_image1"
                        android:layout_width="fill_parent"
                        android:layout_height="100px"
                        android:src="@drawable/noimage" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="fill_parent"
                    android:layout_weight="5" >
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/ll_myphoto_item_imagelayer2"
                    android:layout_width="0dp"
                    android:layout_height="fill_parent"
                    android:layout_weight="50" >

                    <ImageView
                        android:id="@+id/img_myphoto_item_image2"
                        android:layout_width="fill_parent"
                        android:layout_height="100px"
                        android:src="@drawable/noimage" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="fill_parent"
                    android:layout_weight="5" >
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/ll_myphoto_item_imagelayer3"
                    android:layout_width="0dp"
                    android:layout_height="fill_parent"
                    android:layout_weight="50" >

                    <ImageView
                        android:id="@+id/img_myphoto_item_image3"
                        android:layout_width="fill_parent"
                        android:layout_height="100px"
                        android:src="@drawable/noimage" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="fill_parent"
                    android:layout_weight="5" >
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/ll_myphoto_item_imagelayer4"
                    android:layout_width="0dp"
                    android:layout_height="fill_parent"
                    android:layout_weight="50" >

                    <ImageView
                        android:id="@+id/img_myphoto_item_image4"
                        android:layout_width="fill_parent"
                        android:layout_height="100px"
                        android:src="@drawable/noimage" />
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="fill_parent"
            android:layout_weight="5" >
        </LinearLayout>

    </LinearLayout>

</LinearLayout>